@model TH3.Models.Product

@{
    ViewData["Title"] = Model.Name + " - Showcase";
}

<style>
    .display-header {
        height: 70vh;
        width: 100%;
        background-color: #000;
        position: relative;
        overflow: hidden;
    }

    .display-header img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.8;
    }

    .display-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        padding: 50px 0;
        background: linear-gradient(transparent, rgba(0,0,0,0.9));
        color: #fff;
    }

    .spec-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.15rem;
        color: #888;
        margin-bottom: 0.5rem;
    }

    .spec-value {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 2rem;
    }

    .description-container {
        padding: 80px 0;
        line-height: 1.8;
        font-size: 1.1rem;
    }

    .back-btn {
        margin-top: 50px;
        display: inline-block;
        color: var(--porsche-black);
        text-decoration: none;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1rem;
        font-size: 0.75rem;
    }

    .back-btn:hover {
        color: var(--porsche-red);
    }
</style>

<div class="display-header">
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" alt="@Model.Name">
    }
    else
    {
        <img src="/images/taycan-hero.png" alt="Fallback">
    }
    <div class="display-overlay">
        <div class="container">
            <p class="mb-1 text-uppercase letter-spacing-2" style="letter-spacing: 2px;">@Model.Category?.Name</p>
            <h1 class="display-2 fw-black fw-bold">@Model.Name</h1>
        </div>
    </div>
</div>

<div class="container py-5">
    <div class="row mt-5">
        <div class="col-lg-8 pe-lg-5">
            <h3 class="section-title mb-4">The Essence of Performance</h3>
            <div class="description-container pt-0">
                @Model.Description
            </div>
            
            <a asp-action="Index" class="back-btn">← Back to Models</a>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 rounded-0 bg-light p-4">
                <div class="spec-label">Price from</div>
                <div class="spec-value text-dark">@Model.Price.ToString("C0")</div>
                
                <div class="spec-label">Engine</div>
                <div class="spec-value">Turbo Variant</div>
                
                <div class="spec-label">Top Speed</div>
                <div class="spec-value">250 km/h</div>
                
                <button class="btn btn-porsche w-100 py-3 mt-3">Personalize Now</button>
            </div>
        </div>
    </div>
</div>
@model IEnumerable<TH3.Models.Order>
@{
    ViewData["Title"] = "Order Management";
}

<style>
    .order-header {
        padding: 151px 0 50px;
        background-color: #f8f9fa;
        text-align: center;
        margin-bottom: 30px;
    }
    .order-table {
        background: #fff;
        border: 1px solid #eee;
    }
    .status-badge {
        padding: 5px 12px;
        font-size: 0.7rem;
        text-transform: uppercase;
        font-weight: 700;
        border-radius: 0;
    }
</style>

<header class="order-header">
    <div class="container">
        <h1 class="fw-black text-uppercase tracking-widest">Order Management</h1>
        <p class="text-muted">Review and manage customer car orders</p>
    </div>
</header>

<div class="container mb-5">
    <div class="table-responsive">
        <table class="table table-hover order-table">
            <thead class="table-dark text-uppercase small">
                <tr>
                    <th>Order #</th>
                    <th>Customer</th>
                    <th>Order Date</th>
                    <th>Total Price</th>
                    <th>Address</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td class="fw-bold">#@order.Id</td>
                        <td>@order.User?.Email</td>
                        <td>@order.OrderDate.ToString("MMM dd, yyyy HH:mm")</td>
                        <td class="fw-bold text-danger">@order.TotalPrice.ToString("C0")</td>
                        <td class="small">@order.ShippingAddress</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-dark btn-sm rounded-0 text-uppercase fw-bold">View Details</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

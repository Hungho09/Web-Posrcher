@model IEnumerable<TH3.Models.Order>
@{
    ViewData["Title"] = "My Purchase History";
}

<style>
    .order-history-header {
        padding: 151px 0 50px;
        background-color: #f8f9fa;
        text-align: center;
        margin-bottom: 30px;
    }
    .order-card {
        background: #fff;
        border: 1px solid #eee;
        transition: transform 0.3s;
        border-radius: 0;
    }
    .order-id { font-weight: 900; font-size: 0.9rem; letter-spacing: 0.05rem; }
    .status-badge { font-size: 0.65rem; padding: 4px 10px; border-radius: 0; font-weight: 700; text-transform: uppercase; }
</style>

<header class="order-history-header">
    <div class="container">
        <h1 class="fw-black text-uppercase tracking-widest">My Porsche Journey</h1>
        <p class="text-muted">A history of your automotive pursuits</p>
    </div>
</header>

<div class="container mb-5 pb-5">
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <p class="text-muted pb-4">You have not placed any orders yet.</p>
            <a href="/Product" class="btn btn-dark text-uppercase fw-bold rounded-0 px-5 py-3">Explore Our Lineup</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var order in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card order-card h-100 shadow-sm">
                        <div class="card-body p-4 d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="order-id">ORDER #@order.Id</span>
                                <span class="badge bg-danger status-badge">Confirmed</span>
                            </div>
                            <h4 class="fw-black text-danger mb-1">@order.TotalPrice.ToString("C0")</h4>
                            <p class="text-muted small mb-4">Ordered on @order.OrderDate.ToString("MMM dd, yyyy")</p>
                            
                            <div class="mt-auto">
                                <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-outline-dark w-100 rounded-0 text-uppercase fw-bold small">View Order Details</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

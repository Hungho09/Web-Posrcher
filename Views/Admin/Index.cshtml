@model IEnumerable<TH3.Models.Order>
@{
    ViewData["Title"] = "Admin Dashboard";
}

<style>
    .admin-header {
        padding: 151px 0 50px;
        background-color: #1c1c1c;
        color: #fff;
        text-align: center;
        margin-bottom: 50px;
    }
    .stat-card {
        border: none;
        border-radius: 0;
        padding: 30px;
        background: #fff;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        transition: transform 0.3s;
    }
    .stat-card:hover { transform: translateY(-5px); }
    .stat-label { font-size: 0.75rem; text-transform: uppercase; font-weight: 700; color: #888; }
    .stat-value { font-size: 2rem; font-weight: 900; color: #1c1c1c; }
    .recent-orders { background: #fff; border: 1px solid #eee; }
</style>

<header class="admin-header">
    <div class="container">
        <h1 class="fw-black text-uppercase tracking-widest">Administrator Control Panel</h1>
        <p class="text-muted">System management and live data overview</p>
    </div>
</header>

<div class="container mb-5">
    <div class="row mb-5">
        <div class="col-md-3">
            <div class="stat-card">
                <span class="stat-label">Total Products</span>
                <div class="stat-value">@ViewBag.TotalProducts</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <span class="stat-label">Total Orders</span>
                <div class="stat-value">@ViewBag.TotalOrders</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <span class="stat-label">Total Sales</span>
                <div class="stat-value">@(((decimal)ViewBag.TotalSales).ToString("C0"))</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <span class="stat-label">Categories</span>
                <div class="stat-value">@ViewBag.TotalCategories</div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <h3 class="fw-black text-uppercase small mb-4">Recent Orders Activity</h3>
            <div class="recent-orders p-4">
                <table class="table table-hover">
                    <thead class="text-uppercase small">
                        <tr>
                            <th>User</th>
                            <th>Date</th>
                            <th>Total</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td>@order.User?.Email</td>
                                <td>@order.OrderDate.ToString("g")</td>
                                <td class="fw-bold">@order.TotalPrice.ToString("C0")</td>
                                <td><a href="/Order/Details/@order.Id" class="btn btn-dark btn-sm rounded-0">View</a></td>
                            </tr>
                        }
                    </tbody>
                </table>
                <a href="/Order" class="btn btn-outline-dark btn-sm rounded-0 w-100 text-uppercase mt-3">View All Orders</a>
            </div>
        </div>
        <div class="col-md-4">
            <h3 class="fw-black text-uppercase small mb-4">System Shortcuts</h3>
            <div class="list-group rounded-0">
                <a href="/Product/Add" class="list-group-item list-group-item-action py-3">Add New Porsche Model</a>
                <a href="/Product" class="list-group-item list-group-item-action py-3">Inventory Management</a>
                <a href="/Order" class="list-group-item list-group-item-action py-3">Live Order Tracking</a>
                <a href="/Identity/Account/Manage" class="list-group-item list-group-item-action py-3">Admin Profile Settings</a>
            </div>
        </div>
    </div>
</div>
